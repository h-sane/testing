# LLM keys
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

CLAUDE_API_KEY_1=
CLAUDE_API_KEY_2=
CLAUDE_API_KEY_3=

# NVIDIA NIM
NVIDIA_API_KEY_1=
NVIDIA_MODEL=google/gemma-4-31b-it
NVIDIA_CHAT_COMPLETIONS_URL=https://integrate.api.nvidia.com/v1/chat/completions

# AWS Bedrock (bearer auth)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_COMPLEX=amazon.nova-lite-v1:0
BEDROCK_COMPLEX_MODELS=amazon.nova-lite-v1:0,us.anthropic.claude-haiku-4-5-20251001-v1:0,us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_SIMPLE=amazon.nova-lite-v1:0
BEDROCK_SIMPLE_MODELS=amazon.nova-lite-v1:0,us.anthropic.claude-haiku-4-5-20251001-v1:0,amazon.nova-micro-v1:0
SARA_LLM_COMPLEX_PROVIDER=bedrock
SARA_LLM_SIMPLE_PROVIDER=bedrock

# Optional behavior
LLM_STRICT_PREFERRED_PROVIDER=0
SARA_WAKE_WORD=hey sara
SARA_DISABLE_VOICE_INPUT=0
SARA_FORCE_SBERT=0
SARA_ENABLE_CHROMA=1

# Voice pipeline
DEEPGRAM_API_KEY=
SARA_DEEPGRAM_STT_MODEL=nova-2
SARA_DEEPGRAM_STT_LANGUAGE=en
SARA_DEEPGRAM_TTS_MODEL=aura-2-thalia-en
PICOVOICE_ACCESS_KEY=
SARA_WAKE_WORD_PATH=C:/Users/husai/Desktop/CODES/SARA-Hybrid-Assistant/Hey-SARA_en_windows_v3_0_0.ppn
SARA_WAKE_SENSITIVITY=0.6
SARA_VOICE_LISTEN_TIMEOUT_SEC=6
SARA_VOICE_PHRASE_TIME_LIMIT_SEC=12

# Graph memory (Neo4j)
SARA_ENABLE_GRAPH_MEMORY=1
SARA_MEMORY_USER_ID=local-user
SARA_NEO4J_URI=neo4j://127.0.0.1:7687
SARA_NEO4J_USER=neo4j
SARA_NEO4J_PASSWORD=sara@123
SARA_NEO4J_DATABASE=neo4j
